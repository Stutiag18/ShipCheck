# Database (SQLite for local dev - works with no setup)
DATABASE_URL="file:./prisma/dev.db"

# Google Gemini API (get free key at https://aistudio.google.com/app/apikey)
# Leave empty to use demo mode with mock responses
GEMINI_API_KEY=""

# Groq API (get free key at https://console.groq.com/keys)
# Leave empty to use demo mode with mock responses
GROQ_API_KEY=""
